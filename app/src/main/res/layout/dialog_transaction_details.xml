<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="12dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/card_bg_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvDlgType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TRANSACTION DETAILS"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvDlgTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Transaction Title"
            android:textColor="@color/text_dark"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tvDlgDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date: YYYY-MM-DD"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:layout_marginBottom="16dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2E8F0"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Transaction Value"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"/>
            <TextView
                android:id="@+id/tvDlgAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0.00"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description Notes"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"/>
            <TextView
                android:id="@+id/tvDlgNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No additional records."
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.2"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutDlgExpenseDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F8FAFC"
            android:padding="14dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Funded From Source Profile"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"/>
            <TextView
                android:id="@+id/tvDlgLinkedSource"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Source Pool"
                android:textColor="@color/text_dark"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Source Profile Remaining Asset Balance"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvDlgSourceBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0.00"
                android:textColor="@color/income_green"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnDlgClose"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Dismiss Details"
            android:textColor="@color/brand_primary"
            app:backgroundTint="#E2E8F0"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
